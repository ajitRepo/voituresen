# ============================================
# VoitureSen — Configuration (.env)
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# Serveur
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://voituresen.onrender.com

# Claude API (Fatou IA) - REQUIS pour Fatou IA
# Obtenir sur: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# Twilio (Bot WhatsApp) - Optionnel
# Obtenir sur: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886

# Stripe (Paiement carte bancaire) - Optionnel
# Obtenir sur: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PayDunya (Wave / Orange Money) - Optionnel
# Obtenir sur: https://paydunya.com
PAYDUNYA_MASTER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYDUNYA_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYDUNYA_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# APIs VIN (Optionnel - fallback NHTSA gratuit)
CARVERTICAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTODNA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
